NODE_ENV=development
HOST=127.0.0.1
PORT=4000

JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars!!

# XAMPP MySQL (default: root, no password)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=queensdb

# Development: schema sync runs automatically on API startup (creates/updates tables from models).
# Set to false only if you manage schema manually (e.g. pure SQL migrations).
# DB_SYNC_ON_START=false
#
# One-off (e.g. CI): `npm run db:sync` — refuses production unless ALLOW_PRODUCTION_DB_SYNC=1
# ALLOW_PRODUCTION_DB_SYNC=1

# Optional overrides for npm run seed:admin
# SEED_ADMIN_EMAIL=admin@gmail.com
# SEED_ADMIN_PASSWORD=admin@123
#
# Sample inbox rows for the header + sidebar lists (same user as seed:admin by default)
# SEED_INBOX_USER_EMAIL=admin@gmail.com
#
# Dashboard sample data (students, staff, expenses, notices, KPIs, etc.):
#   cd backend && npm run seed:dashboard
#   (or from repo root: npm run seed:dashboard)
# Requires MySQL running and DB_NAME matching what the API uses.

CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Password reset OTP — pick one (Resend is checked first, same pattern as Resend in user.controller.js)
#
# A) Resend — https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="Queens Junior School <onboarding@resend.dev>"
#
# B) Classic SMTP (only if RESEND_API_KEY is unset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Queens SMS <noreply@school.edu>"
#
# If both are unset: in development the OTP is printed in the server console.
